# Pi Ping Monitor example configuration
TARGET_MAIN="192.168.100.1"
TARGET_SIDE="192.168.100.79"
TARGET_MAC="192.168.0.173"
HOTSPOT_SSID="YourHotspotSSID"
HOTSPOT_PASSWORD="YourHotspotPass"
AUTOMATE_HOST="192.168.0.65"
AUTOMATE_PORT="7801"
AUTOMATE_ENDPOINT="failover_token"
SSH_USER="your_mac_username"
SSH_KEY_PATH="/home/your-linux-user/.ssh/id_ed25519_mac"
MAIN_INTERVAL="5"
SIDE_INTERVAL="30"
DEBUG="true"
WEB_PORT=""
